{
  "manifest_version": 3,
  "name": "Pause & Think",
  "version": "1.0",
  "description": "Pause before impulse purchases",
  "permissions": ["storage", "activeTab", "scripting", "alarms", "notifications", "tabs"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/butterfly.png"
  },
  "background": {
    "service_worker": "background.js"
  }
  }
